generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  CUSTOMER
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
  NO_SHOW
}

model User {
  id String @id @default(cuid())

  name  String
  email String @unique
  phone String?

  passwordHash String?

  emailVerified Boolean @default(false)
  isActive      Boolean @default(true)

  role Role @default(CUSTOMER)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  appointments Appointment[]
}

model Service {
  id String @id @default(cuid())

  name        String
  description String?

  duration Int // percben

  price Int // Ft

  active Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  appointments Appointment[]
}

model Appointment {
  id String @id @default(cuid())

  customerId String
  serviceId  String

  startTime DateTime
  endTime   DateTime

  price Int

  status AppointmentStatus @default(PENDING)

  note String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  customer User @relation(fields: [customerId], references: [id], onDelete: Cascade)
  service Service @relation(fields: [serviceId], references: [id])

  @@index([customerId])
  @@index([serviceId])
  @@index([startTime])
  @@index([status])
}

model OpeningHour {
  id        String @id @default(cuid())
  weekday   Int    @unique
  opensAt   String
  closesAt  String
  isClosed  Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Vacation {
  id          String   @id @default(cuid())
  startDate   DateTime
  endDate     DateTime
  reason      String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

